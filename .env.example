# Copy to .env and fill in values. Do not commit .env.

# OpenAI-compatible LLM (OpenRouter recommended)
OPENAI_COMPATIBLE_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_MODEL=inclusionai/ring-2.6-1t:free

# Legacy names (optional; used if OPENAI_COMPATIBLE_* is unset)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=inclusionai/ring-2.6-1t:free

# Postgres (optional overrides for docker compose)
# POSTGRES_DB=newspulse
# POSTGRES_USER=newsuser
# POSTGRES_PASSWORD=newssecret
