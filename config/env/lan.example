# Phone/LAN testing — merge into .env (set NEWSMINE_DEV_HOST only; compose derives URLs).
# Also: cp docker-compose.lan.example.yml docker-compose.override.yml
# Run: ./scripts/dev-host.sh

NEWSMINE_DEV_HOST=YourMac.local

# Optional explicit overrides (use real hostname, not ${...} — env_file does not expand variables)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,YourMac.local
# BASE_URL=http://YourMac.local:8000
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YourMac.local:3000
# NEXT_PUBLIC_API_URL=http://YourMac.local:8000/api

# news-pulse-frontend/.env.local — host only, no port (Next.js HMR)
# ALLOWED_DEV_ORIGINS=YourMac.local
