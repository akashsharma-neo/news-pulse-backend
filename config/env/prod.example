# Copy to .env and fill in all values for production deployment.

NEWSMINE_ENV=prod

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_MODEL=meta-llama/llama-3.1-8b-instruct

# Article chat web search (OpenRouter openrouter:web_search; ~$0.005/search when used)
# CHAT_WEB_SEARCH_ENABLED=true
# CHAT_WEB_SEARCH_MAX_RESULTS=5
# CHAT_WEB_SEARCH_MAX_TOTAL_RESULTS=10

EMBEDDINGS_ENABLED=false
SUMMARIZE_FETCH_FULL_BODY=false
SUMMARIZE_MAX_TOKENS=180

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=
BASE_URL=
CORS_ALLOWED_ORIGINS=
# HTTPS behind reverse proxy (defaults applied when NEWSMINE_ENV=prod)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000

SUMMARIZE_BATCH_SIZE=12
SUMMARIZE_DELAY_SEC=4

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

NEXT_PUBLIC_NEWSMINE_ENV=prod
NEXT_PUBLIC_API_URL=
FRONTEND_URL=https://your-frontend-domain

# Firebase (backend service account JSON or file path)
# FIREBASE_CREDENTIALS_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# Firebase web (frontend — set in news-pulse-frontend deploy env too)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Amazon SES SMTP (see deploy/cloudflare-ses.md)
# EMAIL_HOST=email-smtp.ap-south-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=news@yourdomain.com

# Tab placeholder images (upload articles/static/newspulse/placeholders/ to this S3 prefix)
# PLACEHOLDER_BASE_URL=https://your-bucket.s3.region.amazonaws.com/newspulse/placeholders

# Deploy overlay (EC2): see config/env/prod.deploy.example
