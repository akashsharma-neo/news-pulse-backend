# Copy to .env and fill in all values for production deployment.

NEWSMINE_ENV=prod

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_MODEL=meta-llama/llama-3.1-8b-instruct

EMBEDDINGS_ENABLED=false
SUMMARIZE_FETCH_FULL_BODY=false
SUMMARIZE_MAX_TOKENS=180

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=
BASE_URL=
CORS_ALLOWED_ORIGINS=
# HTTPS behind reverse proxy (defaults applied when NEWSMINE_ENV=prod)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000

SUMMARIZE_BATCH_SIZE=12
SUMMARIZE_DELAY_SEC=4

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

NEXT_PUBLIC_NEWSMINE_ENV=prod
NEXT_PUBLIC_API_URL=

# Amazon SES SMTP (see deploy/cloudflare-ses.md)
# EMAIL_HOST=email-smtp.ap-south-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=news@yourdomain.com

# Tab placeholder images (upload articles/static/newspulse/placeholders/ to this S3 prefix)
# PLACEHOLDER_BASE_URL=https://your-bucket.s3.region.amazonaws.com/newspulse/placeholders

# Deploy overlay (EC2): see config/env/prod.deploy.example
