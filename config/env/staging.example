# Copy to .env and fill in all values for staging deployment.

NEWSMINE_ENV=staging

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_MODEL=meta-llama/llama-3.1-8b-instruct

# CHAT_WEB_SEARCH_ENABLED=true

EMBEDDINGS_ENABLED=false
SUMMARIZE_FETCH_FULL_BODY=false
SUMMARIZE_MAX_TOKENS=180

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=
BASE_URL=
CORS_ALLOWED_ORIGINS=

SUMMARIZE_BATCH_SIZE=12
SUMMARIZE_DELAY_SEC=4

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

NEXT_PUBLIC_NEWSMINE_ENV=staging
NEXT_PUBLIC_API_URL=

# Tab placeholder images (optional S3 prefix; omit to use BASE_URL/static/...)
# PLACEHOLDER_BASE_URL=
